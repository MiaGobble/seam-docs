/* Backup of custom.css before enforcing full dark theme */

/**
 * Any CSS included here will be global. The classic template
 * bundles Infima by default. Infima is a CSS framework designed to
 * work well for content-centric websites.
 */

/* You can override the default Infima variables here. */
:root {
  --ifm-color-primary: #2e8555;
  --ifm-color-primary-dark: #29784c;
  --ifm-color-primary-darker: #277148;
  --ifm-color-primary-darkest: #205d3b;
  --ifm-color-primary-light: #33925d;
  --ifm-color-primary-lighter: #359962;
  --ifm-color-primary-lightest: #3cad6e;
  --ifm-code-font-size: 95%;
  --docusaurus-highlighted-code-line-bg: rgba(0, 0, 0, 0.1);
}

/* For readability concerns, you should choose a lighter palette in dark mode. */
[data-theme='dark'] {
  --ifm-color-primary: #25c2a0;
  --ifm-color-primary-dark: #21af90;
  --ifm-color-primary-darker: #1fa588;
  --ifm-color-primary-darkest: #1a8870;
  --ifm-color-primary-light: #29d5b0;
  --ifm-color-primary-lighter: #32d8b4;
  --ifm-color-primary-lightest: #4fddbf;
  --docusaurus-highlighted-code-line-bg: rgba(0, 0, 0, 0.3);
}

/* Enforce site-wide forced dark theme colors (requested) */
:root {
  /* Primary dark background for the site */
  --site-dark-bg: #121212;
  /* Primary UI/foreground color (buttons, icons, headings, etc) */
  --site-foreground: #E6E6E6;
  /* Normal body text color */
  --site-body-text: #C2C2C2;
}

/* Apply background and base colors globally */
html, body, #__docusaurus, .docusaurus-wrapper {
  background-color: var(--site-dark-bg) !important;
  color: var(--site-body-text) !important;
}

/* Make primary UI elements use the bright foreground color */
*, ::before, ::after {
  color: inherit;
}

/* Headings and important UI use the brighter foreground */
h1, h2, h3, h4, h5, h6, .navbar__brand, .navbar__items a, .docTitle, .hero, .button, button, .infima-btn {
  color: var(--site-foreground) !important;
}

/* Links */
a {
  color: var(--site-foreground) !important;
}

/* Buttons and primary controls */
.button, .infima-btn, button, input[type="button"], input[type="submit"] {
  background-color: transparent !important;
  color: var(--site-foreground) !important;
  border-color: rgba(230,230,230,0.12) !important;
}

/* Cards, docs, and panels - use slightly lighter backgrounds to separate from page bg */
.card, .theme-doc-markdown, .infima-card, .infima-hero {
  background-color: rgba(255,255,255,0.02) !important;
  color: var(--site-body-text) !important;
}

/* Code blocks and pre tags - ensure readable contrast */
code, pre, .prism-react-renderer {
  color: var(--site-foreground) !important;
}

/* Footer adjustments */
.footer, .footer .links a {
  color: var(--site-body-text) !important;
}

/* Make images that are used as logos keep their original colors but ensure visibility on dark bg */
.navbar__brand img, .hero img, .logo {
  filter: none;
}

/* Accessibility: ensure focus outlines are visible on dark bg */
:focus {
  outline: 2px solid rgba(230,230,230,0.12);
  outline-offset: 2px;
}
